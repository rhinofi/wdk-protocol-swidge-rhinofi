{
  "name": "@rhino.fi/wdk-protocol-swidge-rhinofi",
  "version": "1.0.0-beta.1",
  "description": "WDK module to perform cross-chain swaps via the Rhino.fi protocol.",
  "keywords": [
    "wdk",
    "protocol",
    "swidge",
    "rhinofi"
  ],
  "author": "Rhino.fi",
  "license": "Apache-2.0",
  "files": [
    "index.js",
    "bare.js",
    "src",
    "types",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "prepack": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@rhino.fi/sdk": "1.12.4",
    "@tetherto/wdk-wallet": "1.0.0-beta.9",
    "bare-node-runtime": "1.1.4",
    "decimal.js": "10.6.0"
  },
  "devDependencies": {
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.13",
    "cross-env": "7.0.3",
    "jest": "29.7.0",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}